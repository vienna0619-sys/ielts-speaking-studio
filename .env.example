# OpenAI key is read only by the Next.js server. Never prefix it with NEXT_PUBLIC_.
OPENAI_API_KEY=

# Optional provider overrides. Defaults follow the official Audio and Responses API.
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe-2025-12-15
OPENAI_TTS_MODEL=gpt-audio-1.5
OPENAI_TTS_VOICE=marin
# Optional per-preset overrides. When omitted, female presets use marin and male presets use cedar.
OPENAI_TTS_VOICE_GB_FEMALE=
OPENAI_TTS_VOICE_GB_MALE=
OPENAI_TTS_VOICE_US_FEMALE=
OPENAI_TTS_VOICE_US_MALE=
OPENAI_TTS_VOICE_AU_FEMALE=
OPENAI_TTS_VOICE_AU_MALE=
OPENAI_TTS_VOICE_IN_FEMALE=
OPENAI_TTS_VOICE_IN_MALE=
OPENAI_TEXT_MODEL=gpt-5.6-terra

# Optional sanitized server diagnostics. Never logs the API key.
AI_DEBUG_LOGS=0
