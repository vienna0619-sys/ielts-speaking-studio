# OpenAI key is read only by the server runtime. Never use NEXT_PUBLIC_ or VITE_.
OPENAI_API_KEY=your_server_side_key_here

# Static GitHub Pages frontend -> full-stack Sites API.
VITE_AI_API_BASE_URL=https://ielts-speaking-studio.vienna0619.chatgpt.site
AI_ALLOWED_ORIGINS=https://vienna0619-sys.github.io,https://ielts-speaking-studio.vienna0619.chatgpt.site

# Optional provider overrides. Defaults follow the official Responses and Audio APIs.
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TEXT_MODEL=gpt-5.6-terra

# Optional verified per-profile overrides. There is deliberately no generic
# voice fallback because it could silently make every profile use one voice.
# Female profiles default to marin; male profiles default to cedar.
OPENAI_TTS_VOICE_GB_FEMALE=
OPENAI_TTS_VOICE_GB_MALE=
OPENAI_TTS_VOICE_US_FEMALE=

# Optional sanitized server diagnostics. Never logs the API key.
AI_DEBUG_LOGS=0
