{
  "name": "ielts-speaking-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vite",
    "build": "bash scripts/build-verified.sh",
    "build:pages": "vite build --config vite.pages.config.ts",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "lint": "bash scripts/sites-env.sh -- eslint . --ignore-pattern dist --ignore-pattern gh-pages-dist --ignore-pattern .next",
    "typecheck": "tsc --noEmit",
    "validate:artifact": "bash scripts/validate-artifact.sh",
    "test:unit": "node --test tests/core.test.mjs",
    "test:integration": "node --experimental-strip-types --test tests/integration.test.mjs",
    "test": "npm run test:unit && npm run test:integration"
  },
  "dependencies": {
    "next": "16.2.6",
    "openai": "^6.48.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  }
}
